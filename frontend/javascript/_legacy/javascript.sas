    put '// Regulatory Report Generation Function';
    put 'function generateRegulatoryReport(reportType) {';
    put '  var dateInputId = reportType + "-asof";';
    put '  var dateInput = document.getElementById(dateInputId);';
    put '  if (!dateInput) {';
    put '    dateInputId = reportType + "-date";';
    put '    dateInput = document.getElementById(dateInputId);';
    put '  }';
    put '  if (!dateInput) {';
    put '    dateInputId = reportType + "-asof1";';
    put '    dateInput = document.getElementById(dateInputId);';
    put '  }';
    put '  var selectedDate = dateInput ? dateInput.value : null;';
    put '  console.log("Generating " + reportType + " report for date: " + selectedDate);';
    put '  if (!selectedDate || selectedDate.trim() === "") {';
    put '    showNotification("Please select a valid date for the report", "error");';
    put '    return;';
    put '  }';
    put '  showLoading();';
    put '  var params = { param_date: selectedDate };';
    put '  var formData = new URLSearchParams();';
    put '  formData.append("reporting_date", params.param_date);';
    put '  if (reportType === "sama-q17-2") {';
    put '    var londonDateInput = document.getElementById("sama-q17-2-londonDate");';
    put '    if (londonDateInput && londonDateInput.value) {';
    put '      formData.append("london_date", londonDateInput.value);';
    put '    }';
    put '  }';
    put '  if (reportType === "sama-p3") {';
    put '    var londonDateInput = document.getElementById("sama-p3-londonDate");';
    put '    if (londonDateInput && londonDateInput.value) {';
    put '      formData.append("london_date", londonDateInput.value);';
    put '    }';
    put '  }';
    put '  var storedProcedureUrl = "";';
    put '  if (reportType === "saccr-cva") {';
    put '    storedProcedureUrl = "https://enterprisebsl.anb.com.sa/SASStoredProcess/do?&_program=/User Folders/62917/My Folder/Master Tables Preparation/SACCR and CVA/SACCR_CVA_2";';
    put '  } else if (reportType === "sama-p3") {';
    put '    storedProcedureUrl = "https://enterprisebsl.anb.com.sa/SASStoredProcess/do?&_program=/User Folders/62917/My Folder/Market Risk/SAMA_P3_Report_Generator";';
    put '  }';
    put '  fetch(storedProcedureUrl, {';
    put '    method: "POST",';
    put '    headers: {';
    put '      "Content-Type": "application/x-www-form-urlencoded",';
    put '      "Accept": "text/html"';
    put '    },';
    put '    body: formData.toString()';
    put '  })';
    put '  .then(response => {';
    put '    if (!response.ok) {';
    put '      throw new Error("Network response was not ok: " + response.status);';
    put '    }';
    put '    console.log("Stored procedure executed successfully");';
    put '    return response.text();';
    put '  })';
    put '  .then(htmlResponse => {';
    put '    console.log("HTML Response received");';
    put '    showNotification("Master Table Prepared Successfully", "success");';
    put '    hideLoading();';
    put '  })';
    put '  .catch(error => {';
    put '    hideLoading();';
    put '    showNotification("Error generating Master Tables: " + error.message, "error");';
    put '  });';
    put '}';
    put '// View Report History Function';
    put 'function viewReportHistory(reportType) {';
    put '  console.log("Viewing report history for: " + reportType);';
    put '  showNotification("Report history feature coming soon", "info");';
    put '}';
    put '// Set default dates for date inputs if they are empty';
    put 'function setDefaultDates(reportType) {';
    put '  var today = new Date().toISOString().split("T")[0];';
    put '  var dateInputs = document.querySelectorAll("input[type=\"date\"]");';
    put '  dateInputs.forEach(function(input) {';
    put '    if (input.id && input.id.includes(reportType) && !input.value) {';
    put '      input.value = today;';
    put '    }';
    put '  });';
    put '}';

    put '</script>';
%mend generate_javascript_content_gen;
