    put '// Dynamic Prompt Generator';
    put ' function getpromptHTML(reportId, title, description, frequency, fields) {';
    put '  var html = "";';
    put '  html += "<div style=''max-width: 1200px; margin: 0 auto; padding: 20px;''>";';
